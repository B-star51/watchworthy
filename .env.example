# ──────────────────────────────────────────────────────────────────────────
# WatchWorthy environment variables
# Copy this file to `.env` and fill in a key. You only need ONE provider.
# Keys can also be entered at runtime in the in-app Settings panel (⚙),
# which is the recommended path for a deployed demo so no key ships in the bundle.
# ──────────────────────────────────────────────────────────────────────────

# Anthropic (Claude) — primary recommendation agent brain.
# Get a key at https://console.anthropic.com/
VITE_ANTHROPIC_API_KEY=

# GitHub Models — optional alternate agent provider ("GitHub agent").
# Create a fine-grained PAT with the "Models" permission: https://github.com/settings/tokens
VITE_GITHUB_TOKEN=
